# Backend Environment Variables Template
# Copy this file to .env and fill in your actual values

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/jobgenius
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/jobgenius

# OpenAI API Key (for resume parsing)
OPENAI_API_KEY=sk-your-actual-openai-key-here

# RapidAPI key (for jobs recommendations/search)
RAPIDAPI_KEY=your-rapidapi-key

# PostgreSQL Database (for recruiter features)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=jobgenius

# JWT Secret (for authentication)
JWT_SECRET=your-secret-jwt-key-change-this-in-production

# Server Port
PORT=5000

# Google OAuth (optional, for Google Sign-in)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
